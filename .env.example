# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Chat Configuration
ALLOWED_CHATS=[-1001412293127]
REQUEST_CHAT_ID=-1001234567890
REVIEW_CHAT_ID=-1001234567891

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Optional: Sudo Users
SUDO_USERS=[]

# Optional: Custom Telegram Bot API base URL (e.g. nginx reverse proxy)
# Useful in countries where api.telegram.org is blocked
# TELEGRAM_API_BASE_URL=https://your-proxy-server.com

# Optional: base directory for per-job scratch space.
# Downloads, extraction, and dump staging are created under here.
# Must exist and be a directory. Leave unset to use the system tempdir.
# WORK_DIR_BASE=/mnt/big-disk/dumpbot-work
